# =============================================================================
# 🤖 AI FEATURES: 多AI模型配置 (DeepSeek, 通义千问, 豆包)
# =============================================================================
# 
# 重要提示：
# 1. 此文件是配置模板，请复制为 .env.ai 并填入真实API密钥
# 2. .env.ai 文件会被git忽略，确保API密钥安全
# 3. 获取API密钥后，请妥善保管，避免泄露
#
# 使用说明：
# 1. 复制此文件: cp ai_config_example.env .env.ai
# 2. 编辑 .env.ai 文件，填入您的真实API密钥
# 3. 重启应用以加载新配置
# =============================================================================

# DeepSeek - 通过火山方舟访问
AI_DEEPSEEK_API_KEY=your_deepseek_api_key_here
AI_DEEPSEEK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
AI_DEEPSEEK_MODEL_NAME=deepseek-v3-250324

# 通义千问 Configuration (阿里云DashScope)
# 通义千问 API - 设置您的阿里云DashScope API密钥
# 获取API密钥：https://dashscope.console.aliyun.com/
AI_QWEN_API_KEY=your_qwen_api_key_here
AI_QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_QWEN_MODEL_NAME=qwen3-vl-plus

# 豆包 Configuration (字节跳动火山方舟)
# 豆包 API - 设置您的火山方舟API密钥
# 获取API密钥：https://console.volcengine.com/ark/region:ark+cn-beijing/model
AI_DOUBAO_API_KEY=your_doubao_api_key_here
AI_DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
AI_DOUBAO_MODEL_NAME=ep-m-20250814175607-b77g6

# 默认AI模型设置
# 可选值: deepseek, qwen, doubao
AI_DEFAULT_MODEL=deepseek

# AI Summary Model - 默认使用DeepSeek R1 V3作为摘要模型
AI_OPENAI_API_SUMMARY_MODEL=deepseek-reasoner

# AI聊天设置
AI_CHAT_MAX_TOKENS=4096
AI_CHAT_TEMPERATURE=0.7
AI_CHAT_STREAM_ENABLED=true


