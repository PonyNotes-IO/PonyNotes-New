# Development Environment Configuration
# 开发环境配置 - 使用本地服务器
# 使用方法：将此文件复制为 appflowy_flutter/.env 或 appflowy_flutter/dev.env

# 认证类型：4 = appflowyCloudDevelop (开发模式)
AUTHENTICATOR_TYPE=4

# 后端 API 地址（开发环境使用 localhost:9998，通过 nginx 代理）
# AI 请求会自动发送到: APPFLOWY_CLOUD_URL/api/ai
APPFLOWY_CLOUD_URL=http://localhost:9998

# Web 域名（测试环境）
BASE_WEB_DOMAIN=https://test.xiaomabiji.com

# Sentry DSN（可选）
SENTRY_DSN=

# 内部构建标识（可选）
INTERNAL_BUILD=

