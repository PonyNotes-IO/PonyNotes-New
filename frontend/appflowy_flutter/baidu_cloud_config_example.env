# =============================================================================
# 🌩️ 百度网盘集成配置
# =============================================================================
# 
# 重要提示：
# 1. 此文件是配置模板，请复制为 .env.baidu 并填入真实API密钥
# 2. .env.baidu 文件会被git忽略，确保API密钥安全
# 3. 获取API密钥后，请妥善保管，避免泄露
#
# 使用说明：
# 1. 复制此文件: cp baidu_cloud_config_example.env .env.baidu
# 2. 编辑 .env.baidu 文件，填入您的真实API密钥
# 3. 重启应用以加载新配置
# =============================================================================

# 百度网盘开放平台配置
# 获取方式：https://pan.baidu.com/union/document/entrance#/openapi
BAIDU_CLOUD_APP_KEY=your_baidu_app_key_here
BAIDU_CLOUD_SECRET_KEY=your_baidu_secret_key_here
BAIDU_CLOUD_REDIRECT_URI=http://localhost:8080/auth/callback

# 百度网盘API配置
BAIDU_CLOUD_API_BASE=https://pan.baidu.com/rest/2.0
BAIDU_CLOUD_UPLOAD_API=https://d.pcs.baidu.com/rest/2.0/pcs/file

# 文件下载配置
BAIDU_CLOUD_DOWNLOAD_TIMEOUT=300
BAIDU_CLOUD_MAX_FILE_SIZE=1073741824

# 缓存配置
BAIDU_CLOUD_CACHE_EXPIRE_HOURS=24
BAIDU_CLOUD_MAX_CACHE_SIZE=100

# 调试模式
BAIDU_CLOUD_DEBUG_MODE=false
